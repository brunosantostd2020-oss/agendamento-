# ── BANCO DE DADOS ──────────────────────────────────────────
DATABASE_URL=postgresql://user:senha@host:5432/dbname

# ── SESSÃO ──────────────────────────────────────────────────
SESSION_SECRET=troque_por_string_aleatoria_longa_aqui
NODE_ENV=production
PORT=3000

# ── ADMIN MASTER ────────────────────────────────────────────
# Login em /master — painel de controle geral
MASTER_PASSWORD=master@agendaok2024

# ── ADMIN API (admin@agendaok.com no login normal) ──────────
ADMIN_EMAIL=admin@agendaok.com
ADMIN_PASSWORD=admin123

# ── URL BASE DO APP (sem barra final) ───────────────────────
BASE_URL=https://agendaok.online
APP_URL=https://agendaok.online

# ── E-MAIL (Gmail com App Password) ─────────────────────────
# 1. Ative "Verificação em 2 etapas" na sua conta Google
# 2. Acesse: myaccount.google.com/apppasswords
# 3. Crie uma senha de app (16 caracteres) e cole abaixo
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── BACKUP SEMANAL DO BANCO ─────────────────────────────────
# Todo domingo 4h (BR) um .json.gz com todos os dados chega neste e-mail.
# Se vazio, usa EMAIL_USER. Teste manual: POST /admin/backup-agora (logado no /master)
BACKUP_EMAIL=

# ── DADOS PIX (para e-mail de instruções de pagamento) ──────
PIX_CHAVE=seupix@email.com
PIX_NOME=Seu Nome
PIX_BANCO=Banco do Brasil

# ── MERCADO PAGO ────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel
# Use o token de PRODUÇÃO (APP_USR-...) ou TESTE (TEST-...)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
