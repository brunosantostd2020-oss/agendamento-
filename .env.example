# ════════════════════════════════════════════════════════
#  AgendaOK — Variáveis de Ambiente
#  ATENÇÃO: Copie este arquivo para .env e preencha os valores
#  NUNCA suba o arquivo .env para o GitHub
# ════════════════════════════════════════════════════════

# ── SERVIDOR ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── SESSÃO (gere uma string aleatória longa) ─────────────
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_AQUI

# ── BANCO DE DADOS ────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# ── ACESSO MASTER (seu painel de admin) ──────────────────
MASTER_USER=SEU_USUARIO_AQUI
MASTER_SENHA=SUA_SENHA_AQUI

# ── E-MAIL (Gmail com senha de app) ──────────────────────
# 1. Ative verificação em 2 etapas no Gmail
# 2. Acesse: myaccount.google.com/apppasswords
# 3. Crie senha de app e cole abaixo (sem espaços)
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=xxxxxxxxxxxxxxxxxxxx

# ── PIX (para informar aos clientes) ─────────────────────
PIX_CHAVE=sua_chave_pix
PIX_NOME=Seu Nome Completo
PIX_BANCO=Seu Banco

# ── URL BASE (produção) ───────────────────────────────────
BASE_URL=https://seusite.railway.app
