ADMIN_EMAIL=admin@agendaok.com
ADMIN_PASSWORD=admin123
MASTER_PASSWORD=master@agendaok2024
NODE_ENV=production

# ── BANCO DE DADOS ───────────────────────────────
# Fornecido automaticamente pelo Railway (PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── URL BASE DO SITE ─────────────────────────────
# Sem barra no final
BASE_URL=https://seusite.up.railway.app

# ── E-MAIL (Gmail) ──────────────────────────────
# 1. Ative "Verificacao em 2 etapas" no Gmail
# 2. Acesse: myaccount.google.com/apppasswords
# 3. Crie uma senha de app e cole abaixo
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── WEB PUSH (opcional) ──────────────────────────
# Para notificacoes nativas no celular mesmo com app fechado
# Gerar com: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:seuemail@gmail.com
